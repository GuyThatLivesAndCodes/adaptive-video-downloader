{
  "name": "adaptive-video-downloader",
  "version": "1.0.0",
  "description": "Cross-browser extension that detects adaptive (HLS) video segments and downloads + merges them into one file.",
  "private": true,
  "type": "module",
  "scripts": {
    "icons": "node tools/make-icons.mjs",
    "vendor": "mkdir -p src/vendor/ffmpeg && cp node_modules/@ffmpeg/ffmpeg/dist/umd/ffmpeg.js node_modules/@ffmpeg/ffmpeg/dist/umd/814.ffmpeg.js node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.js node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.wasm src/vendor/ffmpeg/",
    "build": "bash build.sh"
  },
  "license": "MIT",
  "devDependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "0.12.15"
  }
}
